generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  NEW_ORDER
  ADVANCE_PAID
  SENT_TO_TAILOR
  READY
  DISPATCHED
  DELIVERED
}

enum OrderSource {
  FACEBOOK
  INSTAGRAM
  WHATSAPP
  WEBSITE
}

enum DeliveryZone {
  INSIDE_DHAKA
  OUTSIDE_DHAKA
}

model Order {
  id             String       @id @default(cuid())
  orderNumber    Int          @unique @default(autoincrement())
  customerName   String
  phone          String
  address        String
  imageUrl       String?
  sizeDetails    String?
  totalPrice     Int
  advanceAmount  Int          @default(500)
  deliveryCharge Int          @default(80)
  deliveryZone   DeliveryZone @default(INSIDE_DHAKA)
  codAmount      Int
  source         OrderSource  @default(FACEBOOK)
  status         OrderStatus  @default(NEW_ORDER)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([customerName])
  @@index([phone])
}
